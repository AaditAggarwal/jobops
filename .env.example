# Copy to .env and fill in. .env is gitignored — never commit real values.

# Postgres connection string. Matches docker-compose.yml defaults for local dev.
DATABASE_URL=postgresql://jobops:jobops@localhost:5432/jobops

# Anthropic API key for LLM calls (resume tailoring, JD scoring, cover letters).
ANTHROPIC_API_KEY=

# Discord webhook URL for instant new-job notifications.
DISCORD_WEBHOOK=

# GitHub personal access token (public_repo read) for github_repos poller —
# raises the unauthenticated rate limit when watching new-grad job repos.
GH_PAT=

# Google OAuth desktop-flow files for Gmail/Calendar integration.
# credentials.json comes from Google Cloud Console; token.json is created by
# the OAuth flow on first run. Both are gitignored.
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json
